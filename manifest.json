{
  "manifest_version": 3,
  "name": "PokerNow Odds Calculator",
  "version": "1.1.0",
  "description": "Real-time poker odds calculator overlay for PokerNow.club",
  "host_permissions": [
    "*://pokernow.com/*",
    "*://*.pokernow.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://pokernow.com/*",
        "*://*.pokernow.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
